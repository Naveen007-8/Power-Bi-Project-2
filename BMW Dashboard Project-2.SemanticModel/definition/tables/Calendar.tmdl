		sourceColumn: [Weektype]

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDARAUTO(),
				    "Year", YEAR([Date]),
				    "Month", FORMAT([Date],"mmm"),
				    "Monthnum", MONTH([Date]),
				    "Weekday", FORMAT([Date],"ddd"),
				    "Weeknum", WEEKDAY([Date]),
				    "QTR", "Q-" & FORMAT([Date],"Q"),
				    "Weektype", IF(WEEKDAY([Date])=1 || WEEKDAY([Date])=7,"Weekend","Weekday")
				)

	annotation PBI_Id = b0ac9ea6bb594ed3a28e360f0d637fc5

